{
  "name": "@agentcenter/cli",
  "version": "0.2.0",
  "description": "AgentCenter CLI — install and manage AI agent extensions",
  "type": "module",
  "bin": {
    "agentcenter": "./dist/agentcenter.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build --target=node --minify src/index.ts --outfile dist/agentcenter.js",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fflate": "^0.8.2",
    "smol-toml": "^1.3.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.13",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
