# Postgres connection (Supabase, self-hosted, or any Postgres)
DATABASE_URL="postgresql://user:pass@host:5432/agentcenter"

# App origin — used by Better Auth and for share/OG URLs
NUXT_PUBLIC_APP_URL="http://localhost:3000"
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Supabase Storage (default — comment out and use R2_* vars to switch)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="agentcenter-bundles"

# Cloudflare R2 (alternative to Supabase Storage)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="agentcenter-bundles"

# Inngest (background jobs)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
