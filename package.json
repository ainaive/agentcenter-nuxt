{
  "name": "agentcenter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate": "bun run prepare && bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxtjs/i18n": "^10.3.0",
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^4.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4",
    "@types/node": "^22.10.0",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
